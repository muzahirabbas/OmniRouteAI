{
  "name": "omniroute-local-daemon",
  "version": "1.0.0",
  "description": "OmniRouteAI Local CLI Daemon — exposes AI CLI tools via HTTP on localhost:5059",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "start": "node src/main.js",
    "dev": "node --watch src/main.js",
    "build:win": "pkg src/main.js --target node18-win-x64 --output dist/OmniRouteAI-Local.exe --assets src/**",
    "build:linux": "pkg src/main.js --target node18-linux-x64 --output dist/OmniRouteAI-Local",
    "build:mac": "pkg src/main.js --target node18-macos-x64 --output dist/OmniRouteAI-Local-mac",
    "build:all": "npm run build:win && npm run build:linux && npm run build:mac"
  },
  "dependencies": {
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "src/**/*.js",
    "assets": [],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64",
      "node18-macos-x64"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
